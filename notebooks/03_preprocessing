------------------------------------\ng = (df.groupby(\"gene\")\n        .agg(sym=(\"cgc_symbols\",\"first\"), n=(\"label\",\"size\"),\n             pos=(\"label\",\"sum\"), movers=(\"is_hard_test\",\"sum\"))\n        .reset_index())\n\n# ---- TEST = top-K mover-genes (deterministic) ------------------------------\nmg = g[g.movers > 0].sort_values([\"movers\",\"n\",\"gene\"], ascending=[False,False,True])\ntest_genes = set(mg.head(K_TEST)[\"gene\"])\npool = g[~g.gene.isin(test_genes)]\n\n# ---- VAL = smallest held-out positive-bearing genes until ~12% of pool pos --\nval_pos_target = VAL_POS_FRAC * pool.pos.sum()\npos_genes = pool[pool.pos > 0].sort_values([\"pos\",\"n\",\"gene\"], ascending=[True,True,True])\nval_genes, vp = set(), 0\nfor r in pos_genes.itertuples(index=False):\n    if vp >= val_pos_target:\n        break\n    val_genes.add(r.gene); vp += int(r.pos)\n\n# ---- assemble gene -> split map, apply to every variant --------------------\ngene_split = {gn: \"test\" for gn in test_genes}\ngene_split.update({gn: \"val\" for gn in val_genes})\ndf[\"split\"]     = df[\"gene\"].map(lambda gn: gene_split.get(gn, \"train\"))\ndf[\"hard_eval\"] = df[\"is_hard_test\"] & (df[\"split\"] == \"test\")\n\n# ---- CORRECTNESS ASSERTIONS (the leakage guarantees) -----------------------\nassert df[\"split\"].notna().all(), \"a variant has no split — gene missing from map\"\nstraddle = df.groupby(\"gene\")[\"split\"].nunique()\nassert (straddle == 1).all(), f\"LEAKAGE: {int((straddle>1).sum())} genes straddle splits\"\nS = {s: set(df[df.split == s].gene) for s in [\"train\",\"val\",\"test\"]}\nassert not (S[\"train\"] & S[\"val\"]) and not (S[\"train\"] & S[\"test\"]) and not (S[\"val\"] & S[\"test\"])\nassert len(S[\"train\"]) + len(S[\"val\"]) + len(S[\"test\"]) == df.gene.nunique()\nassert (df.loc[df.hard_eval, \"split\"] == \"test\").all()\nprint(\"assertions passed — no gene straddles splits; hard-eval is fully test-side\\n\")\n\n# ---- report --------------------------