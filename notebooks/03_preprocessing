\"labeled\"] += 1\n\n        gi = d.get(\"GENEINFO\", \"\")\n        if not gi:\n            c[\"no_geneinfo\"] += 1\n            continue\n        pairs = [p.rsplit(\":\", 1) for p in gi.split(\"|\") if \":\" in p]\n        hits  = [(s, g) for s, g in pairs if g in CGC_MAP]\n        if not hits:\n            continue\n        c[\"cgc_ok\"] += 1\n        if len(hits) > 1:\n            c[\"multi_cgc_gene\"] += 1\n\n        rows.append({\n            \"variation_id\": f[2],\n            \"chrom\": chrom,\n            \"pos\": int(f[1]),\n            \"ref\": ref,\n            \"alt\": alt,\n            \"label\": label,\n            \"clnsig\": sig,\n            \"clnrevstat\": d[\"CLNREVSTAT\"],\n            \"cgc_gene_ids\": \",\".join(g for _, g in hits),\n            \"cgc_symbols\": \",\".join(s for s, _ in hits),\n            \"cgc_tiers\": \",\".join(CGC_MAP[g][1] for _, g in hits),\n            \"all_gene_ids\": \",\".join(g for _, g in pairs),\n            \"mc\": d.get(\"MC\", \"\"),\n        })\n\ndf = pd.DataFrame(rows)\ndf.to_parquet(f\"{OUT_DIR}/clinvar_cgc_snv.parquet\", index=False)\nprint(f\"\\nsaved -> {OUT_DIR}/clinvar_cgc_snv.parquet  ({len(df):,} rows)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T07:55:02.46478Z","iopub.execute_input":"2026-07-21T07:55:02.465633Z","iopub.status.idle":"2026-07-21T07:55:38.789422Z","shell.execute_reply.started":"2026-07-21T07:55:02.4656Z","shell.execute_reply":"2026-07-21T07:55:38.788427Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os, re, gzip, requests\nimport pandas as pd\nfrom collections import Counter\nfrom datetime import date\n\nOUT_DIR = \"/kaggle/working/phase2\"\nPARQUET = f\"{OUT_DIR}/clinvar_cgc_snv.parquet\"\nARCHIVE = \"https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/archive_2.0/2022/\"\nTARGET  = date(2022, 7, 6)          # ~4 years before your current 2026-07-06 set\n\nassert os.path.exists(PARQUET), (\n    \"Missing Step-1 parquet. Fresh session? Re-run the Step 1 filter first \"\n    \"(pip install cell not needed here — this cell only uses requests/pandas).\"\n)\n\ndef norm(c):                        # defensive chrom normalizer\n    return str(c).replace(\"chr\", \"\").replace(\"Chr\", \"\").strip()\n\n# ---- current confident P/B CGC set: the keys we care about -----------------\ncur = pd.read_parquet(PARQUET, columns=[\"chrom\",\"pos\",\"ref\",\"alt\",\"label\",\"cgc_symbols\"])\ncurrent, sym = {}, {}\nfor r in cur.itertuples(index=False):\n    k = (norm(r.chrom), int(r.pos), r.ref.upper(), r.alt.upper())\n    current[k] = r.label\n    sym[k]     = r.cgc_symbols\nprint(f\"current confident P/B CGC SNVs: {len(current):,}\")\n\n# ---- discover a real 2022 monthly filename from the live index -------------\nresp = requests.get(ARCHIVE, timeout=60); resp.raise_for_status()\ndates = sorted(set(re.findall(r'clinvar_(2022\\d{4})\\.vcf\\.gz', resp.text)))\nassert dates, (\"Parsed no clinvar_2022*.vcf.gz from the index — paste the \"\n               \"directory listing back and I'll pick one manually.\")\nto_d = lambda s: date(int(s[:4]), int(s[4:6]), int(s[6:8]))\npick = min(dates, key=lambda s: abs((to_d(s) - TARGET).days))\nurl   = f\"{ARCHIVE}clinvar_{pick}.vcf.gz\"\nlocal = f\"{OUT_DIR}/clinvar_{pick}.vcf.gz\"\nprint(f\"2022 releases available: {len(dates)} | closest to {TARGET}: {pick}\")\n\n# ---- download (idempotent) -------------------------------------------------\nif not os.path.exists(local) or os.path.getsize(local) < 1_000_000:\n    print(f\"downloading {url} ...\")\n    with requests.get(url, stream=True, timeout=600) as d:\n        d.raise_for_status()\n        with open(local, \"wb\") as fh:\n            for chunk in d.iter_content(1 << 20):\n                fh.write(chunk)\nprint(f\"2022 file: {local}  ({os.path.getsize(local)/1e6:.1f} MB)\")\n\n# ---- constants -------------------------------------------------------------\nSTAR2 = {\"criteria_provided,_multiple_submitters,_no_conflicts\",\n         \"reviewed_by_expert_panel\", \"practice_guideline\"}\nSTAR1 = {\"criteria_provided,_single_submitter\"}\nPOS   = {\"Pathogenic\",\"Likely_pathogenic\",\"Pathogenic/Likely_pathogenic\"}\nNEG   = {\"Benign\",\"Likely_benign\",\"Benign/Likely_benign\"}\n\ndef parse_info(s):\n    o = {}\n    for kv in s.split(\";\"):\n        k, _, v = kv.partition(\"=\")\n        o[k] = v\n    return o\n\n# ---- stream 2022; record status only for keys already in `current` ---------\nstatus, seen = {}, 0\nwith gzip.open(local, \"rt\") as fh:\n    for line in fh:\n        if line[0] == \"#\":\n            continue\n        seen += 1\n        f = line.rstrip(\"\\n\").split(\"\\t\")\n        if len(f) < 8:\n            continue\n        key = (norm(f[0]), int(f[1]), f[3].upper(), f[4].upper())\n        if key not in current:\n            continue\n        d = parse_info(f[7])\n        status[key] = (d.get(\"CLNSIG\",\"\"), d.get(\"CLNREVSTAT\",\"\"))\nprint(f\"\\n2022 records scanned: {seen:,}\")\nprint(f\"of {len(current):,} current variants, {len(status):,} were present in 2022\")\n\n# ---- classify each current variant by its 2022 standing --------------------\nbuckets, movers = Counter(), []\nfor k, label_now in current.items():\n    if k not in status:\n        buckets[\"absent_2022\"] += 1;  continue\n    sig, rev = status[k]\n    if \"Uncertain_significance\" in sig:\n        buckets[\"vus_2022\"] += 1\n        star = 2 if rev in STAR2 else (1 if rev in STAR1 else 0)\n        movers.append((k, label_now, star))\n    elif \"Conflicting\" in sig:\n        buckets[\"conflicting_2022\"] += 1\n    elif sig in POS or sig in NEG:\n        buckets[\"stable_confident_2022\"] += 1\n    else:\n        buckets[\"other_2022\"] += 1\n\n# ---- report ----------------------------------------------------------------\nprint(\"\\n--- where your current confident variants stood in 2022 ---\")\nfor k in [\"stable_confident_2022\",\"vus_2022\",\"conflicting_2022\",\"other_2022\",\"absent_2022\"]:\n    print(f\"{k:<24} {buckets[k]:>8,}\")\nprint(\"(sanity: stable_confident should be large; if absent_2022 is ~all of it, the join broke)\")\n\nprint(\"\\n=== MOVERS: VUS in 2022  ->  confident P/B now ===\")\ntot     = len(movers)\nnow_pos = sum(1 for _, l, _ in movers if l == 1)\nprint(f\"TOTAL movers: {tot:,}   (now pathogenic {now_pos:,} / benign {tot-now_pos:,})\")\nfor s, name in [(2,\"gold  2022 >=2*\"), (1,\"1*    single submitter\"), (0,\"0*    no criteria\")]:\n    sub = [m for m in movers if m[2] == s]\n    p   = sum(1 for _, l, _ in sub if l == 1)\n    print(f\"  {name:<24} {len(sub):>6,}   (path {p:,} / benign {len(sub)-p:,})\")\n\ngc = Counter(sym[k].split(\",\")[0] for k, _, _ in movers)\nprint(f\"\\nmovers span {len(gc)} genes; top: \" +\n      \", \".join(f\"{g}={n}\" for g, n in gc.most_common(8)))\n\n# ---- persist mover membership (used by Step 2b if the gate passes) ---------\npd.DataFrame([{\"chrom\":k[0],\"pos\":k[1],\"ref\":k[2],\"alt\":k[3],\n               \"label\":l,\"star_2022\":s,\"gene\":sym[k].split(\",\")[0]}\n              for k, l, s in movers]).to_parquet(f\"{OUT_DIR}/vus_movers.parquet\", index=False)\n\nprint(\"\\n>>> GATE:\", \"PASS\" if tot >= 500 else \"MARGINAL/FAIL\",\n      f\"(total movers {tot:,} vs ~500 threshold)\")\nprint(f\"saved -> {OUT_DIR}/vus_movers.parquet\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T07:56:00.437514Z","iopub.execute_input":"2026-07-21T07:56:00.438252Z","iopub.status.idle":"2026-07-21T07:56:08.422194Z","shell.execute_reply.started":"2026-07-21T07:56:00.438217Z","shell.execute_reply":"2026-07-21T07:56:08.421363Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os, glob\nimport pysam\nimport pandas as pd\nfrom collections import Counter\n\nPH   = \"/kaggle/working/phase2\"\nPARQ = f\"{PH}/clinvar_cgc_snv.parquet\"\nMOV  = f\"{PH}/vus_movers.parquet\"\nW, HALF = 1024, 512                      # extract 1024 bp; variant sits at index 512\n\n# ---- locate genome + index -------------------------------------------------\nfa_hits = glob.glob(\"/kaggle/input/datasets/lazarvelinov46/cancer-variant-lm-raw/*primary_assembly.fa\")\nassert fa_hits, \"GRCh38 primary_assembly.fa not found — attach lazarvelinov46/cancer-variant-lm-raw\"\nFASTA = fa_hits[0]\nassert os.path.exists(FASTA + \".fai\"), (\n    f\"{FASTA}.fai missing — pysam needs the index and the input dir is read-only. \"\n    \"Confirm the .fai is inside the dataset.\"\n)\nassert os.path.exists(PARQ), \"clinvar_cgc_snv.parquet missing — re-run Step 1 in this session.\"\n\n# ---- load variants; drop the 31 multi-CGC-gene variants --------------------\ndf = pd.read_parquet(PARQ)\nbefore = len(df)\ndf = df[~df.cgc_gene_ids.str.contains(\",\")].reset_index(drop=True)\nprint(f\"variants: {before:,} -> {len(df):,} after dropping {before-len(df)} multi-CGC-gene rows\")\n\n# ---- hard-test membership (tag if the movers file is present) --------------\nmover_keys = set()\nif os.path.exists(MOV):\n    mv = pd.read_parquet(MOV)\n    mover_keys = {(str(r.chrom), int(r.pos), r.ref.upper(), r.alt.upper())\n                  for r in mv.itertuples(index=False)}\n    print(f\"loaded {len(mover_keys):,} mover keys for hard-test tagging\")\nelse:\n    print(\"WARN: vus_movers.parquet not found — is_hard_test will be all False; back-fill later\")\n\n# ---- open genome, verify every contig we need is present -------------------\nref = pysam.FastaFile(FASTA)\nclen = dict(zip(ref.references, ref.lengths))\nmissing = sorted(set(df.chrom) - set(clen))\nassert not missing, f\"these contigs are not in the FASTA: {missing}\"\nprint(f\"FASTA contigs OK; will read from {df.chrom.nunique()} chromosomes\")\n\n# ---- extract, sorted by (chrom,pos) for faidx locality ---------------------\ndf = df.sort_values([\"chrom\", \"pos\"], kind=\"stable\").reset_index(drop=True)\nwindows, offsets, winlens = [], [], []\nmism, clamped, examples = 0, 0, []\n\nfor r in df.itertuples(index=False):\n    v0    = r.pos - 1                          # 1-based VCF POS -> 0-based\n    start = v0 - HALF\n    L     = clen[r.chrom]\n    cs, ce = max(0, start), min(L, start + W)  # clamp at contig edges\n    win    = ref.fetch(r.chrom, cs, ce).upper()\n    off    = v0 - cs                           # index of variant within window\n    if cs != start or ce != start + W:\n        clamped += 1\n    # ---- THE GATE: FASTA base at variant must equal VCF REF ----------------\n    if not (0 <= off < len(win) and win[off] == r.ref.upper()):\n        mism += 1\n        if len(examples) < 8:\n            got = win[off] if 0 <= off < len(win) else \"OOB\"\n            examples.append(f\"{r.chrom}:{r.pos} REF={r.ref} FASTA={got}\")\n    windows.append(win); offsets.append(off); winlens.append(len(win))\n\nprint(f\"\\n=== GATE: FASTA base == VCF REF ===\")\nprint(f\"mismatches: {mism:,}   (MUST be 0)\")\nif mism:\n    print(\"examples:\"); [print(\"  \", e) for e in examples]\n    print(\"\\nABORT — coordinate conversion is wrong, not saving. Do not proceed.\")\nelse:\n    df[\"ref_window\"]   = windows\n    df[\"offset\"]       = offsets\n    df[\"win_len\"]      = winlens\n    df[\"is_hard_test\"] = [(str(r.chrom), int(r.pos), r.ref.upper(), r.alt.upper()) in mover_keys\n                          for r in df.itertuples(index=False)]\n    out = f\"{PH}/variant_windows_1024.parquet\"\n    df.to_parquet(out, index=False)\n\n    print(\"GATE PASSED — every window's centre base matches the reference.\\n\")\n    print(f\"rows saved            : {len(df):,}\")\n    print(f\"class balance         : path {int((df.label==1).sum()):,} / \"\n          f\"benign {int((df.label==0).sum()):,}\")\n    print(f\"hard-test (movers)    : {int(df.is_hard_test.sum()):,}\")\n    print(f\"edge-clamped windows  : {clamped:,}  (expect ~0; short windows near contig ends)\")\n    print(f\"window length distn   : \"\n          f\"{dict(Counter(winlens).most_common(3))}  (expect almost all == {W})\")\n    print(f\"\\nsaved -> {out}  ({os.path.getsize(out)/1e6:.1f} MB)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T07:58:39.739322Z","iopub.execute_input":"2026-07-21T07:58:39.739699Z","iopub.status.idle":"2026-07-21T07:58:43.745632Z","shell.execute_reply.started":"2026-07-21T07:58:39.739667Z","shell.execute_reply":"2026-07-21T07:58:43.744733Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import pandas as pd\n\nPH = \"/kaggle/working/phase2\"\ndf = pd.read_parquet(f\"{PH}/variant_windows_1024.parquet\",\n                     columns=[\"label\",\"cgc_gene_ids\",\"cgc_symbols\",\"is_hard_test\"])\ndf = df.rename(columns={\"cgc_gene_ids\": \"gene\", \"cgc_symbols\": \"sym\"})  # single-valued post-drop\nN = len(df)\n\n# ---- gene-level table ------------------------------------------------------\ng = df.groupby(\"gene\").agg(n=(\"label\",\"size\"),\n                           pos=(\"label\",\"sum\"),\n                           movers=(\"is_hard_test\",\"sum\"),\n                           sym=(\"sym\",\"first\"))\ng[\"neg\"] = g.n - g.pos\nprint(f\"genes: {len(g)} | variants: {N:,} | pos {int(g.pos.sum()):,} / neg {int(g.neg.sum()):,} \"\n      f\"({g.pos.sum()/N:.1%} positive)\")\nprint(f\"gene size: median {g.n.median():.0f}, p90 {g.n.quantile(.9):.0f}, max {int(g.n.max()):,}\")\n\nmg = g[g.movers > 0].sort_values(\"movers\", ascending=False)\nfree = g[g.movers == 0]\nprint(f\"\\nmover-genes : {len(mg):>4}  holding {int(mg.n.sum()):>7,} variants ({mg.n.sum()/N:5.1%} of data) \"\n      f\"| median size {mg.n.median():.0f}\")\nprint(f\"mover-free  : {len(free):>4}  holding {int(free.n.sum()):>7,} variants ({free.n.sum()/N:5.1%} of data) \"\n      f\"| median size {free.n.median():.0f}\")\nprint(f\"total movers: {int(mg.movers.sum()):,}  (path {int(df[df.is_hard_test].label.sum()):,} / \"\n      f\"benign {int((~df[df.is_hard_test].label.astype(bool)).sum()):,})\")\n\n# ---- Decision 4 tradeoff curve --