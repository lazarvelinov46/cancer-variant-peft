{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":18220962}],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# Phase 3 · Step 1b — Two-direction validation rebalance (CPU)\n# Buy the positives val needs from train (minimal spend), then shed benign-skewed\n# val genes BACK to train to reach the target ratio for free. Whole genes move.\n# Restart from the ORIGINAL split — do not build on the step-1 checkpoint.\n\nimport pandas as pd, numpy as np\n\nSPLIT_PARQUET = \"/kaggle/input/datasets/lazarvelinov46/cancer-variant-peft-processed/variant_windows_1024_split.parquet\"\nOUT_PARQUET   = \"/kaggle/working/variant_windows_1024_split.rebalanced.parquet\"\n\n# --- knobs -----------------------------------------------------------------\nTARGET_VAL_RATIO = 0.17     # natural ratio; test is 19.2%\nVAL_POS_TARGET   = 1200     # enough for stable max-MCC threshold; beyond this we're burning train pool\nVAL_POS_FLOOR    = 1000     # never shed below this\nTRAIN_POS_FLOOR  = 4800     # >= 2.3x the 2,048 needed at balanced N=4096\nMIN_GENE_POS     = 5\nPROTECT_GENES    = set()    # keep in train, e.g. {\"673\",\"3845\",\"4893\",\"5290\",\"1029\"} = BRAF,KRAS,NRAS,PIK3CA,CDKN2A\n# ---------------------------------------------------------------------------\n\ndf = pd.read_parquet(SPLIT_PARQUET)\ndf[\"gene\"] = df[\"gene\"].astype(str)\nbefore = df[\"split\"].copy()\ntest_genes_before = frozenset(df.loc[df.split == \"test\", \"gene\"].unique())\ntest_idx_before   = df.index[df.split == \"test\"]\n\ndef show(frame, tag):\n    print(tag)\n    for sp in [\"train\", \"val\", \"test\"]:\n        s = frame[frame.split == sp]\n        n, pos = len(s), int(s.label.sum())\n        print(f\"  {sp:5} {s.gene.nunique():>4} genes  {n:>6} vars  {pos:>5} pos  ({pos/n:6.1%})\")\n\nshow(df, \"BEFORE:\")\n\ngstat = (df.groupby([\"gene\", \"split\"])\n           .agg(n=(\"label\", \"size\"), pos=(\"label\", \"sum\"))\n           .reset_index())\ngstat[\"ratio\"] = gstat.pos / gstat.n\n\nval_n  = int(gstat.loc[gstat.split == \"val\", \"n\"].sum())\nval_p  = int(gstat.loc[gstat.split == \"val\", \"pos\"].sum())\ntr_p   = int(gstat.loc[gstat.split == \"train\", \"pos\"].sum())\n\n# --- STEP A: buy positives from train (enriched first, fewest genes) --------\nbuy = (gstat[(gstat.split == \"train\") & (gstat.pos >= MIN_GENE_POS)\n             & (~gstat.gene.isin(PROTECT_GENES))]\n       .sort_values([\"ratio\", \"pos\", \"gene\"], ascending=[False, False, True]))\n\nto_val = []\nfor r in buy.itertuples():\n    if val_p >= VAL_POS_TARGET: break\n    if tr_p - int(r.pos) < TRAIN_POS_FLOOR: continue\n    to_val.append(r.gene); val_n += int(r.n); val_p += int(r.pos); tr_p -= int(r.pos)\nto_val = set(to_val)\nprint(f\"\\nA) bought {len(to_val)} genes train->val | val pos {val_p} | train pos left {tr_p}\")\n\n# --- STEP B: shed benign-skewed original val genes back to train (free) -----\nshed_pool = (gstat[(gstat.split == \"val\")]\n             .sort_values([\"ratio\", \"n\", \"gene\"], ascending=[True, False, True]))\n\nto_train = []\nfor r in shed_pool.itertuples():\n    if val_p / val_n >= TARGET_VAL_RATIO: break\n    if val_p - int(r.pos) < VAL_POS_FLOOR: continue\n    to_train.append(r.gene); val_n -= int(r.n); val_p -= int(r.pos)\nto_train = set(to_train)\nprint(f\"B) shed   {len(to_train)} genes val->train | val {val_n} vars / {val_p} pos ({val_p/val_n:.1%})\")\nif val_p / val_n < TARGET_VAL_RATIO:\n    print(\"!! still short of target — loosen VAL_POS_FLOOR or accept the ratio\")\n\n# --- apply -----------------------------------------------------------------\nreb = df.copy()\nreb.loc[reb.gene.isin(to_val),   \"split\"] = \"val\"\nreb.loc[reb.gene.isin(to_train), \"split\"] = \"train\"\nshow(reb, \"\\nAFTER:\")\n\nvpos = reb[(reb.split == \"val\") & (reb.label == 1)].gene.value_counts()\nprint(f\"\\nval positive spread: top gene {vpos.iloc[0]/vpos.sum():.1%}, \"\n      f\"top-3 {vpos.iloc[:3].sum()/vpos.sum():.1%}, across {vpos.size} genes\")\ntp = int(reb.loc[reb.split == \"train\", \"label\"].sum())\nprint(f\"train positives: {tp}  ({tp/2048:.2f}x the N=4096 need)\")\nprint(\"bought (train->val):\", sorted(to_val))\n\n# --- assertions ------------------------------------------------------------\nstraddle = reb.groupby(\"gene\").split.nunique()\nassert (straddle == 1).all(), straddle[straddle > 1]\nassert frozenset(reb.loc[reb.split == \"test\", \"gene\"].unique()) == test_genes_before\nassert reb.index[reb.split == \"test\"].equals(test_idx_before)\nassert reb.loc[test_idx_before, \"split\"].eq(\"test\").all()\nassert (before == \"test\").sum() == (reb.split == \"test\").sum() == len(test_idx_before)\nassert len(reb) == len(df)\nassert not (to_val & to_train)\nprint(\"\\nassertions passed: gene-disjoint · test frozen · no double-move · row count intact\")\n\nreb.to_parquet(OUT_PARQUET, index=False)\nprint(\"checkpointed ->\", OUT_PARQUET)","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-07-22T09:26:01.001897Z","iopub.execute_input":"2026-07-22T09:26:01.00224Z","iopub.status.idle":"2026-07-22T09:26:02.653708Z","shell.execute_reply.started":"2026-07-22T09:26:01.002211Z","shell.execute_reply":"2026-07-22T09:26:02.652862Z"}},"outputs":[{"name":"stdout","text":"BEFORE:\n  train  417 genes   33044 vars   5653 pos  ( 17.1%)\n  val    172 genes   10647 vars    781 pos  (  7.3%)\n  test    40 genes   48328 vars   9284 pos  ( 19.2%)\n\nA) bought 9 genes train->val | va